              },
              {
                "params": [
                  " / 1000"
                ],
                "type": "math"
              }
            ]
          ],
          "tags": [],
          "tz": "Europe/Berlin"
        },
        {
          "alias": "Haus",
          "datasource": {
            "type": "influxdb",
            "uid": "evcc-influxdb"
          },
          "hide": false,
          "query": "SELECT \"value\" *(-1)/1000 FROM \"autogen\".\"homePower\" WHERE $timeFilter tz('$timezone')",
          "rawQuery": true,
          "refId": "Haus",
          "resultFormat": "time_series"
        },
        {
          "alias": "Heizlüfter",
          "datasource": {
            "type": "influxdb",
            "uid": "evcc-influxdb"
          },
          "hide": true,
          "query": "SELECT \"value\" *(-1)/1000 FROM \"extPower\" WHERE $timeFilter tz('$timezone')",
          "rawQuery": true,
          "refId": "Ext",
          "resultFormat": "time_series"
        },
        {
          "alias": "Speicher",
          "datasource": {
            "type": "influxdb",
            "uid": "evcc-influxdb"
          },
          "hide": false,
          "query": "SELECT \"value\"  / 1000 FROM \"autogen\".\"batteryPower\" WHERE $timeFilter AND (\"id\"::tag = '') tz('$timezone')",
          "rawQuery": true,
          "refId": "Speicher",
          "resultFormat": "time_series"
        },
        {
          "alias": "$tag_loadpoint",
          "datasource": {
            "type": "influxdb",
            "uid": "evcc-influxdb"
          },
          "groupBy": [
            {
              "params": [
                "$__interval"
              ],
              "type": "time"
            },
            {
              "params": [
                "loadpoint::tag"
              ],
              "type": "tag"
            },
            {
              "params": [
                "null"
              ],
              "type": "fill"
            }
          ],
          "hide": false,
          "measurement": "chargePower",
          "orderByTime": "ASC",
          "policy": "default",
          "query": "SELECT last(\"value\") *(-1)/1000 FROM \"chargePower\" WHERE $timeFilter AND \"loadpoint\"::tag !~ $loadpointBlocklist GROUP BY \"loadpoint\"::tag fill(null) tz('$timezone') ",
